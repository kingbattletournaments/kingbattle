# Supabase Configuration (REQUIRED for production/Vercel — without these, admin data will NOT persist)
# NEXT_PUBLIC_SUPABASE_URL should be the URL of your Supabase project (available in settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# SUPABASE_SERVICE_ROLE_KEY is the secret API key for backend access (do NOT expose on client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT/Session Secret (REQUIRED for production — min 32 characters)
# APP_SESSION_SECRET is a random string used to sign session cookies
APP_SESSION_SECRET=your-random-app-session-secret-string-min-32-chars

# ZapUPI Payment Gateway Configuration
# ZAPUPI_KEY is your API key from ZapUPI dashboard (set to "test" for sandbox/mock payment environment)
ZAPUPI_KEY=your-zapupi-api-key

# ZAPUPI_WEBHOOK_URL is the absolute URL to receive payment status webhooks from ZapUPI (e.g. https://yourdomain.com/api/deposits/zapupi/webhook)
ZAPUPI_WEBHOOK_URL=https://your-website-domain.vercel.app/api/deposits/zapupi/webhook

# Firebase Cloud Messaging (REQUIRED for admin push notifications)
# Option A — paste the full service account JSON from Firebase Console > Project settings > Service accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"kingbattle-11afd",...}

# Option B — individual fields from the same service account JSON
# FIREBASE_PROJECT_ID=kingbattle-11afd
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kingbattle-11afd.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# End of environment template

# Public website — direct APK download link shown on homepage (optional)
# NEXT_PUBLIC_APK_DOWNLOAD_URL=https://kingbattle-tournaments.vercel.app/kingbattle.apk
